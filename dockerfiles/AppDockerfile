FROM python:3.14.3-trixie

# Expose uvicorn port
EXPOSE 80

# Expose Pudb (debugger) port
EXPOSE 1984

WORKDIR /deploy

# Copy requirements file (needed now).
COPY src/requirements.txt /deploy/

# Update image packages.
RUN apt-get update

# Create and set a locale file.
RUN apt-get install -y locales
RUN echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
RUN locale-gen en_US.UTF-8

# Install and upgrade pip.
RUN python -m pip install --upgrade pip

# Install requirements (requirements-dev.txt can be manually installed in your docker local environment).
RUN pip install --no-cache-dir -r requirements.txt

# Starts FastAPI server.
# TODO: Remove --reload on production.
CMD ["uvicorn", "fastapi_template.main:app", "--host", "0.0.0.0", "--port", "80", "--reload"]
